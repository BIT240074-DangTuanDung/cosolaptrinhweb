@model lession2.Models.LoginViewModel

<h2>Đăng nhập</h2>

@if (ViewBag.Message != null)
{
    <div class="alert @(ViewBag.Message == "Login success" ? "alert-success" : "alert-danger")">
        @ViewBag.Message
    </div>
}

<form asp-action="Login" asp-controller="Account" method="post">
    <div>
        <label asp-for="Username">Username</label>
        <input asp-for="Username" class="form-control" />
    </div>
    <div class="mt-2">
        <label asp-for="Password">Password</label>
        <input asp-for="Password" type="password" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary mt-3">Đăng nhập</button>
</form>

<p class="text-muted mt-3">Thử: admin / 123</p>
