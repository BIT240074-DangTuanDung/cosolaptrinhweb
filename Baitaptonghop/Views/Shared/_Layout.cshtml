<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="bg-primary text-white py-3 mb-3">
        <div class="container">
            <h1 class="h3 mb-0">Website quản lý</h1>
        </div>
    </header>

    <nav class="container mb-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary btn-sm me-2">Home</a>
        <a asp-controller="Student" asp-action="Index" class="btn btn-outline-primary btn-sm">Student</a>
    </nav>

    <main class="container pb-3">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted py-3 mt-4">
        <div class="container text-center">
            <p class="mb-0">ASP.NET MVC Practice</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
